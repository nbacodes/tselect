+  return _scaled_mm_cpu_v2_out(
+    mat_a,
+    mat_b,
+    scale_a,
+    scale_recipe_a,
+    swizzle_a,
+    scale_b,
+    scale_recipe_b,
+    swizzle_b,
+    bias,
+    out_dtype,
+    contraction_dim,
+    use_fast_accum,
+    out);

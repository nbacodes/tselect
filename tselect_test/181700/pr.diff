+        # Clear global state
+        self.registry._libs.clear()
+        self.registry._graphs.clear()
+        self.registry._dsl_name_to_lib_graph.clear()
+        self.registry._dispatch_key_to_lib_graph.clear()
+        self.registry._op_symbol_to_lib_graph.clear()
+

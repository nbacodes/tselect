+
+        result1 = compiled(torch.tensor([0.0]))
+        self.assertEqual(result1, torch.tensor([0.0]))
+        self.assertEqual(cnt.frame_count, 1)
+
+        MyClass.y = 99
+        result2 = compiled(torch.tensor([0.0]))

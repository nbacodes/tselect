+            rhs = RegisteredContainer(torch.ones(2, 3), torch.zeros(2, 3))
+
+            def fn(a, b):
+                return python_pytree.tree_map(lambda x, y: x + y, a, b)
+
+            compiled = torch.compile(fn, backend="eager", fullgraph=True)
